  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Painted in 1565 as part of a series depicting the months of the year,
    The Harvesters captures the height of summer with extraordinary detail. Bruegel
    portrays peasant life with dignity \u2014 workers rest under a pear tree, eat
    their midday meal, and labor in the golden fields. The vast aerial perspective
    and warm amber palette make this one of the most celebrated landscape paintings
    in Western art"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
